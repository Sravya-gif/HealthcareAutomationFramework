<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Healthcare Automation Suite" parallel="tests" thread-count="2">

    <!-- Listener for Extent Report + Screenshot -->
    <listeners>
        <listener class-name="com.srm.listeners.TestListener"/>
    </listeners>

    <test name="Healthcare Tests">

        <classes>

            <!-- 🔹 Module 1: Authentication -->
            <class name="com.srm.tests.LoginTest"/>
            <class name="com.srm.tests.LogoutTest"/>

            <!-- 🔹 Module 2: Appointment Booking -->
            <class name="com.srm.tests.AppointmentTest"/>

            <!-- 🔹 Module 3: History -->
            <class name="com.srm.tests.HistoryTest"/>

            <!-- 🔹 Module 4: Multiple Appointments -->
            <class name="com.srm.tests.MultipleAppointmentTest"/>

            <!-- 🔹 Module 5: Validations -->
            <class name="com.srm.tests.ValidationTest"/>
            <class name="com.srm.tests.CommentValidationTest"/>

        </classes>

    </test>

</suite>